# Copy this file to `.env` (no extension before the dot) and fill in
# your OpenAI public API key. The `.env` file is gitignored.
#
# This key is used ONLY for System 2's embedding pipeline
# (text-embedding-3-small). System 1 does not need it.
# System 2's LLM judge uses the Azure deployment configured in
# openai_creds.yaml (separate file).

OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional overrides:
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small   # supported: -3-small, -3-large, ada-002
# OPENAI_EMBEDDING_BATCH=100
# (dimension is fixed per model - no override knob; see SYSTEM 2 RAG/solution/config.py)
